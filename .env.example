# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/frazier_vcrm

# Contact sources (configure at least one)
ICLOUD_USERNAME=
ICLOUD_APP_PASSWORD=
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI classification + draft generation
DEEPSEEK_API_KEY=

# LinkedIn enrichment (job change detection)
PROXYCURL_API_KEY=

# News (optional, supplements Google RSS)
BING_NEWS_API_KEY=

# Email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=digest@yourdomain.com
DIGEST_TO_EMAIL=you@fraziervc.com

# Tuning
VIP_AUTO_APPROVE_THRESHOLD=0.85
COOLDOWN_DAYS=14
