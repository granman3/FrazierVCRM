# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chiefofstaff

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Platform Admin (first user with this email becomes platform admin)
PLATFORM_ADMIN_EMAIL=your-email@example.com

# Encryption Key (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-32-byte-encryption-key-base64

# External APIs
PROXYCURL_API_KEY=your-proxycurl-api-key
BING_NEWS_API_KEY=your-bing-news-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
RESEND_API_KEY=your-resend-api-key

# Email
RESEND_FROM_EMAIL=digest@yourdomain.com
